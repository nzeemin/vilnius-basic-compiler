;#####################################################################
;## WRSTR
; Печать строки
; R0 = адрес строки, первый байт строки содержит длину строки
WRSTR:
	CLR	R2
	BISB	(R0)+, R2	; берём длину строки
	BEQ	9$		; пустая строка => выходим
1$:	MOVB	(R0)+, R1
2$:	TSTB	@#177564	; Источник канала 0 готов?
	BPL	2$		; нет => ждём
	MOV	R1, @#177566	; передаём символ в канал 0
	SOB	R2, 1$
9$:	RETURN

