; Шаблон рантайм процедур для УКНЦ
;
;#####################################################################
;## WRCHR
; Печать одного символа; R0 = символ
WRCHR:
20$:	TSTB	@#177564	; Источник канала 0 готов?
	BPL	20$		; нет => ждём
	MOV	R0, @#177566	; передаём символ в канал 0
	RETURN

;#####################################################################
;## WREOL
;## Need WRSTR
; Печать перевода строки
WREOL:
	MOV	#CRLF, R0
	JMP	WRSTR
CRLF:	.ASCIZ	<2><015><012>
	.EVEN

