;#####################################################################
;## WRSPC
;## Need WRCHR
; Подпрограмма: PRINT SPC(N), печать пробелов
; R0 = количество пробелов, 1..255
WRSPC:
	MOV	R0, R1
	MOV	#040, R0	; пробел
1$:	CALL	WRCHR
	SOB	R1, 1$
	RETURN

