; Шаблон рантайм процедур для БК-0010
;
;#####################################################################
;## WRCHR
; Печать одного символа; R0 = символ
WRCHR:
	EMT     16              ; передача символа драйверу дисплея
	RETURN

;#####################################################################
;## WREOL
; Печать перевода строки
WREOL:
	MOV	#10, R0
        EMT     16
	RETURN

