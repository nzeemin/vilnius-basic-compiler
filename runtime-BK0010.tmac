;TODO
	RETURN

;#####################################################################
;## WRINT
; Печать целого числа как -32768..32767
; R0 = целое число
WRINT:
	MOV	R0, R4
	BPL	1$
	MOV	#'-, R0         ; минус
	EMT     16              ; передача символа драйверу дисплея
	NEG	R4
1$:	MOV	#060, R0
4$:	SUB	#023420, R4	; 10000.
	BMI	16$
	INC     R0
	BR      4$
16$:	ADD	#023420, R4
	EMT     16              ; передача символа драйверу дисплея
	MOV	#060, R0
30$:	SUB	#001750, R4	; 1000.
	BMI	42$
	INC     R0
	BR      30$
42$:	ADD	#001750, R4	; готова цифра тысяч
	EMT     16              ; передача символа драйверу дисплея
	MOV	#060, R0
54$:	SUB	#000144, R4	; 100.
	BMI	66$
	INC	R0
	BR	54$
66$:	ADD	#000144, R4	; Готова цифра сотен
	EMT     16              ; передача символа драйверу дисплея
	MOV	#060, R0
100$:	SUB	#000012, R4
	BMI	112$
	INC	R0
	BR	100$
112$:	ADD	#000012, R4	; готова цифра десятков
	EMT     16              ; передача символа драйверу дисплея
	MOV	#060, R0
	ADD	R4, R0		; готова последняя цифра
	EMT     16              ; передача символа драйверу дисплея
	RETURN

