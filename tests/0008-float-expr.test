-q
----------------------------------------------------------------------
10 CLS
' Float expressions test
30 A = +1
35 PRINT "1", A
40 A = A + 2
45 PRINT "3", A
50 B = 1.11 + 2.22 + 3.33
55 PRINT "6.66", B
60 A = 1 + 2 + 3 * 4
65 PRINT "15", A
70 B = 1 + 2 + 3 * 4 + 50 - 10
75 PRINT "55", B
80 C = -100
85 PRINT "-100", C
90 D = C + 200
95 PRINT "100", D
100 E = 4
105 PRINT "4", E
110 F = 2 * (10 + 3) / E
115 PRINT "7", F
170 G = 5 ^ 2
175 PRINT "25", G
' Test unary/binary minus
190 A = -1
191 PRINT "-1", A
192 A = 10-1
193 PRINT "9", A
194 A = -10-1
195 PRINT "-11", A
' Test some functions
200 A = 100
201 A = SQR(A)
202 PRINT "10", A
205 A = PI/2
206 A = SIN(A)
207 PRINT "1", A
210 A = PI/2
211 A = COS(A)
212 PRINT "1", A
215 A = PI/4
216 A = TAN(A)
217 PRINT "1", A
220 A = 0
221 A = ATN(A)
222 PRINT "0", A
225 A = 3
226 A = EXP(LOG(A))
228 PRINT "3", A
230 A = -5.3
231 B% = FIX(A)
232 C% = CINT(A)
233 PRINT "-5", B%, C%
245 A = -5.3
246 B% = INT(A)
247 PRINT "-6", B%
260 A = -50.5
261 A = SGN(A)
262 PRINT "-1", A
270 A = RND(-1)
271 PRINT A
280 B% = -123%
281 A = CSNG(B%)
282 PRINT "-123", A
