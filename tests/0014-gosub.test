-q
----------------------------------------------------------------------
700 RETURN
800 GOSUB 700
810 GOSUB 700 'comment
820 GOSUB 700'comment
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 700 RETURN
L700:
	RETURN
; 800 GOSUB 700
L800:
	CALL	L700
; 810 GOSUB 700 'comment
L810:
	CALL	L700
; 820 GOSUB 700'comment
L820:
	CALL	L700
L65536:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
;
	.END	START
