-q
----------------------------------------------------------------------
700 RETURN
800 GOSUB 700
810 GOSUB 700 'comment
820 GOSUB 700'comment
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
; йОЙГЙБМЙЪБГЙС РТПЗТБННЩ
	MTPS	#340			; disable interrupts
	CLR	@#177560
	MTPS	#0			; enable interrupts
	MOV	SP, SAVESP
; 700 RETURN
N700:
	RETURN
; 800 GOSUB 700
N800:
	CALL	N700
; 810 GOSUB 700 'comment
N810:
	CALL	N700
; 820 GOSUB 700'comment
N820:
	CALL	N700
LEND:
; ъБЧЕТЫЕОЙЕ РТПЗТБННЩ
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350		; .EXIT
; STRINGS
	.EVEN
ST0:	.WORD	0	; empty string
; RUNTIME CALLS
	.END	START
