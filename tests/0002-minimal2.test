-q
----------------------------------------------------------------------
?
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MTPS	#340		; disable interrupts
	CLR	@#177560
	MTPS	#0		; enable interrupts
	MOV	SP, SAVESP
; 1 ?
L1:
	CALL	WREOL
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
	.GLOBL	WREOL
;
	.END	START
