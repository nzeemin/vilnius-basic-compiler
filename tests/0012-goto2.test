-q
----------------------------------------------------------------------
1 CLS
GOTO 65535
20 GOTO 1000
50    GOTO 10000
100 GOTO 20
    GOTO 20
200 GOTO 200
1000 GOTO   50
10000 GOTO 100
	GOTO 200
65535 GOTO 1
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 1 CLS
N1:
	MOV	#14, R0
	CALL	WRCHR
; GOTO 65535
L2:
	JMP	N65535
; 20 GOTO 1000
N20:
	JMP	N1000
; 50    GOTO 10000
N50:
	JMP	N10000
; 100 GOTO 20
N100:
	JMP	N20
;     GOTO 20
L6:
	JMP	N20
; 200 GOTO 200
N200:
	JMP	N200
; 1000 GOTO   50
N1000:
	JMP	N50
; 10000 GOTO 100
N10000:
	JMP	N100
; 	GOTO 200
L10:
	JMP	N200
; 65535 GOTO 1
N65535:
	JMP	N1
L_END:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
	.GLOBL	WRCHR
	.END	START
