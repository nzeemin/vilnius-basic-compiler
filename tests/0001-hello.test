-q
----------------------------------------------------------------------
10 A%=23.42
20 PRINT A%
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 10 A%=23.42
N10:
	MOV	#23., VARIA	; assignment
; 20 PRINT A%
N20:
	MOV	VARIA, R0
	CALL	WRINT
	CALL	WREOL
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; VARIABLES
	.EVEN
VARIA:	.WORD	0	; A%
; RUNTIME CALLS
	.GLOBL	WREOL, WRINT
	.END	START
