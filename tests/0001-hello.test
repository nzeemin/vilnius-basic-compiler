-q
----------------------------------------------------------------------
10 A%=23.42
20 PRINT A%
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
; йОЙГЙБМЙЪБГЙС РТПЗТБННЩ
	MTPS	#340			; disable interrupts
	CLR	@#177560
	MTPS	#0			; enable interrupts
	MOV	SP, SAVESP
; 10 A%=23.42
N10:
	MOV	#23., VARIA	; var A% assignment
; 20 PRINT A%
N20:
	MOV	VARIA, R0	; var A%
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
LEND:
; ъБЧЕТЫЕОЙЕ РТПЗТБННЩ
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350		; .EXIT
; STRINGS
	.EVEN
ST0:	.WORD	0	; empty string
; VARIABLES
	.EVEN
VARIA:	.WORD	0	; A%
; RUNTIME CALLS
	.GLOBL	WREOL, WRINT
	.END	START
