----------------------------------------------------------------------
10 A%=23.42
20 PRINT A%
----------------------------------------------------------------------
----------------------------------------------------------------------
	.MCALL	.EXIT
START:
; 10 A%=23.42
L10:
	MOV	#23., VARIA	; assignment
; 20 PRINT A%
L20:
	MOV	VARIA, R0
	CALL	WRINT
	CALL	WRCRLF
L65536:
	.EXIT
; VARIABLES
VARIA:	.WORD	0	; A%
	.END	START
