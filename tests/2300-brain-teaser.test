3100 ?AT(X%,Y%+2);A$
3110 ?AT(X%,Y%+3);B$
3120 ?AT(X%,Y%+4);A$
3130 RETURN
3140 ?AT(X%,Y%+0);A$
3150 ?AT(X%,Y%+1);D$
3160 ?AT(X%,Y%+2);" ";CHR$(127);" "
3170 ?AT(X%,Y%+3);C$
3180 ?AT(X%,Y%+4);C$
3190 RETURN
3200 ?AT(X%,Y%+0);A$
3210 ?AT(X%,Y%+1);B$
3220 ?AT(X%,Y%+2);A$
3230 ?AT(X%,Y%+3);B$
3240 ?AT(X%,Y%+4);A$
3250 RETURN
