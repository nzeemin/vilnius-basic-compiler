2920 ?AT(X%,Y%+2);A$
2930 ?AT(X%,Y%+3);D$
2940 ?AT(X%,Y%+4);A$
2950 RETURN
2960 ?AT(X%,Y%+0);B$
2970 ?AT(X%,Y%+1);B$
2980 ?AT(X%,Y%+2);A$
2990 ?AT(X%,Y%+3);D$
3000 ?AT(X%,Y%+4);D$
3010 RETURN
3020 ?AT(X%,Y%+0);A$
