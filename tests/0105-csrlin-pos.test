-q
----------------------------------------------------------------------
100 Y%=CSRLIN
105 Y%=CSRLIN(X%)
110 Y%=CSRLIN(X%-5)
200 X%=POS
205 X%=POS(Y%)
210 X%=POS(Y%+2)
----------------------------------------------------------------------
WARNING: at 2:8 line 105 - CSRLIN argument calculated but value not used; consider to remove the argument
WARNING: at 3:8 line 110 - CSRLIN argument calculated but value not used; consider to remove the argument
WARNING: at 5:8 line 205 - POS argument calculated but value not used; consider to remove the argument
WARNING: at 6:8 line 210 - POS argument calculated but value not used; consider to remove the argument
----------------------------------------------------------------------
START:
	MTPS	#340		; disable interrupts
	CLR	@#177560
	MTPS	#0		; enable interrupts
	MOV	SP, SAVESP
; 100 Y%=CSRLIN
N100:
	CALL	GETCR		; get cursor pos for CSRLIN
	MOV	R2, R0		; row
	MOV	R0, VARIY	; var Y% assignment
; 105 Y%=CSRLIN(X%)
N105:
	CALL	GETCR		; get cursor pos for CSRLIN
	MOV	R2, R0		; row
	MOV	R0, VARIY	; var Y% assignment
; 110 Y%=CSRLIN(X%-5)
N110:
	MOV	VARIX, R0	; var X%
	CALL	ITOF		; to Single
	CLR	-(SP)		; const 5.
	MOV	#040640, -(SP)
	FSUB	SP		; Operation '-'
	CALL	GETCR		; get cursor pos for CSRLIN
	MOV	R2, R0		; row
	MOV	R0, VARIY	; var Y% assignment
; 200 X%=POS
N200:
	CALL	GETCR		; get cursor pos for POS
	MOV	R1, R0		; column
	MOV	R0, VARIX	; var X% assignment
; 205 X%=POS(Y%)
N205:
	CALL	GETCR		; get cursor pos for POS
	MOV	R1, R0		; column
	MOV	R0, VARIX	; var X% assignment
; 210 X%=POS(Y%+2)
N210:
	MOV	VARIY, R0	; var Y%
	CALL	ITOF		; to Single
	CLR	-(SP)		; const 2.
	MOV	#040400, -(SP)
	FADD	SP		; Operation '+'
	CALL	GETCR		; get cursor pos for POS
	MOV	R1, R0		; column
	MOV	R0, VARIX	; var X% assignment
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350		; .EXIT
; VARIABLES
	.EVEN
VARIX:	.WORD	0	; X%
VARIY:	.WORD	0	; Y%
; RUNTIME CALLS
	.GLOBL	GETCR, ITOF
	.END	START
