-q
----------------------------------------------------------------------
10 CLS
20 CLS 'comment
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MTPS	#340		; disable interrupts
	CLR	@#177560
	MTPS	#0		; enable interrupts
	MOV	SP, SAVESP
; 10 CLS
N10:
	MOV	#14, R0
	CALL	WRCHR
; 20 CLS 'comment
N20:
	MOV	#14, R0
	CALL	WRCHR
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
	.GLOBL	WRCHR
;
	.END	START
