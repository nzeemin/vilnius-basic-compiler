-q
----------------------------------------------------------------------
700 RETURN
800 GOSUB 700
810 GOSUB 700 'comment
820 GOSUB 700'comment
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 700 RETURN
N700:
	RETURN
; 800 GOSUB 700
N800:
	CALL	N700
; 810 GOSUB 700 'comment
N810:
	CALL	N700
; 820 GOSUB 700'comment
N820:
	CALL	N700
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
;
	.END	START
