-q
----------------------------------------------------------------------
1  GOTO 65535
20 GOTO 1000
50    GOTO 10000
100 GOTO 20
101 GOTO 20
200 GOTO 200
1000 GOTO   50
10000 GOTO 100
65535 GOTO 1
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 1  GOTO 65535
L1:
	JMP	L65535
; 20 GOTO 1000
L20:
	JMP	L1000
; 50    GOTO 10000
L50:
	JMP	L10000
; 100 GOTO 20
L100:
	JMP	L20
; 101 GOTO 20
L101:
	JMP	L20
; 200 GOTO 200
L200:
	JMP	L200
; 1000 GOTO   50
L1000:
	JMP	L50
; 10000 GOTO 100
L10000:
	JMP	L100
; 65535 GOTO 1
L65535:
	JMP	L1
L65536:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
;
	.END	START
