-q
----------------------------------------------------------------------
1  GOSUB 65535
20 GOSUB 1000
50  GOSUB 10000
80  RETURN
90 END
100 GOSUB 20
1000 GOSUB   50
10000 GOSUB 100
65535 RETURN
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
; 1  GOSUB 65535
L1:
	CALL	L65535
; 20 GOSUB 1000
L20:
	CALL	L1000
; 50  GOSUB 10000
L50:
	CALL	L10000
; 80  RETURN
L80:
	RETURN
; 90 END
L90:
	JMP	L65536
; 100 GOSUB 20
L100:
	CALL	L20
; 1000 GOSUB   50
L1000:
	CALL	L50
; 10000 GOSUB 100
L10000:
	CALL	L100
; 65535 RETURN
L65535:
	RETURN
L65536:
	EMT	350	; .EXIT
	.END	START
