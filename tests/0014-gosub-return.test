-q
----------------------------------------------------------------------
1  GOSUB 65535
20 GOSUB 1000
50  GOSUB 10000
80  RETURN
90 END
100 GOSUB 20
1000 GOSUB   50
10000 GOSUB 100
65535 RETURN
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 1  GOSUB 65535
N1:
	CALL	N65535
; 20 GOSUB 1000
N20:
	CALL	N1000
; 50  GOSUB 10000
N50:
	CALL	N10000
; 80  RETURN
N80:
	RETURN
; 90 END
N90:
	JMP	L_END
; 100 GOSUB 20
N100:
	CALL	N20
; 1000 GOSUB   50
N1000:
	CALL	N50
; 10000 GOSUB 100
N10000:
	CALL	N100
; 65535 RETURN
N65535:
	RETURN
L_END:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350	; .EXIT
; RUNTIME CALLS
;
	.END	START
