-q
----------------------------------------------------------------------
10 A = 0
11 IF 1 THEN 21 ELSE A = 0
20 GOTO 20
21 IF 1 THEN 21 ELSE GOTO 20
30 GOSUB 30
31 IF 1 THEN 31 ELSE GOSUB 30
40 RETURN
41 IF 1 THEN 41 ELSE RETURN
50 ON A GOTO 10,20,30
51 IF 1 THEN ON A GOTO 10,20,30 ELSE 51
60 STOP
61 IF 1 THEN 61 ELSE STOP
70 DIM B
71 IF 1 THEN 71 ELSE DIM C
80 READ A
81 IF 1 THEN 81 ELSE READ A
90 RESTORE
91 IF 1 THEN 91 ELSE RESTORE
100 PRINT A
101 IF 1 THEN 101 ELSE PRINT A
102 IF 0 THEN 101 ELSE PRINT A
110 INPUT A
111 IF 1 THEN 111 ELSE INPUT A
112 IF 0 THEN 111 ELSE INPUT A
