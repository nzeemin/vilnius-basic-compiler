-q
----------------------------------------------------------------------
1 B% = 1600%
5 ? B% / -5%
6 ? B% / -4%
7 ? B% / -2%
8 ? B% / -1%
10 ? B% / 1%
20 ? B% / 2%
30 ? B% / 3%
40 ? B% / 4%
50 ? B% / 5%
80 ? B% / 8%
160 ? B% / 16%
320 ? B% / 32%
640 ? B% / 64%
----------------------------------------------------------------------
WARNING: at 6:11 line 10 - Division by 1 reduced to nothing, consider to remove the Division.
----------------------------------------------------------------------
START:
	MOV	SP, SAVESP
; 1 B% = 1600%
N1:
	MOV	#1600., VARIB	; var B% assignment
; 5 ? B% / -5%
N5:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#-5., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 6 ? B% / -4%
N6:
	MOV	VARIB, R0	; var B%
	NEG	R0		; * -1
	ASR	R0
	ASR	R0		; / 4
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 7 ? B% / -2%
N7:
	MOV	VARIB, R0	; var B%
	NEG	R0		; * -1
	ASR	R0		; / 2
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 8 ? B% / -1%
N8:
	MOV	VARIB, R0	; var B%
	NEG	R0		; / -1
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 10 ? B% / 1%
N10:
	MOV	VARIB, R0	; var B%
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 20 ? B% / 2%
N20:
	MOV	VARIB, R0	; var B%
	ASR	R0		; / 2
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 30 ? B% / 3%
N30:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#3., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 40 ? B% / 4%
N40:
	MOV	VARIB, R0	; var B%
	ASR	R0
	ASR	R0		; / 4
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 50 ? B% / 5%
N50:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#5., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 80 ? B% / 8%
N80:
	MOV	VARIB, R0	; var B%
	ASH	#-3, R0		; / 8.
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 160 ? B% / 16%
N160:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#16., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 320 ? B% / 32%
N320:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#32., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
; 640 ? B% / 64%
N640:
	MOV	VARIB, R0	; var B%
	MOV	R0, R1
	MOV	#64., R0
	CALL	IDIV		; Operation '/'
	CALL	WRINT		; PRINT Integer
	CALL	WREOL
LEND:
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350		; .EXIT
; VARIABLES
	.EVEN
VARIB:	.WORD	0	; B%
; RUNTIME CALLS
	.GLOBL	WREOL, WRINT, IDIV
	.END	START
