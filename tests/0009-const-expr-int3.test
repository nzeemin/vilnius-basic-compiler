-q
----------------------------------------------------------------------
10 CLS
100 REM Expressions with AND, OR, XOR
101 ? "0",  0% AND 1%
102 ? "1",  1% AND 3%
105 ? "0",  0% OR  0%
106 ? "1",  0% OR  1%
107 ? "3",  1% OR  3%
110 ? "0",  0% XOR 0%
111 ? "1",  0% XOR 1%
112 ? "2",  1% XOR 3%
115 ? "-1", 0% EQV 0%
116 ? "0",  0% EQV 1%
117 ? "0",  1% EQV 0%
118 ? "-1", 1% EQV 1%
120 ? "-1", 0% IMP 0%
121 ? "-1", 0% IMP 1%
122 ? "0",  1% IMP 0%
123 ? "-1", 1% IMP 1%
200 REM Complex expressions
205 PRINT "125", 10% * 10% + 5% * 5%
210 PRINT "216", 1200% MOD 1000% + 2% * 8%
215 PRINT "456", 1200% MOD 1000% + 2% ^ 8%
