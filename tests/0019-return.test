-q
----------------------------------------------------------------------
200 RETURN
210 RETURN
300 RETURN'with comment
----------------------------------------------------------------------
----------------------------------------------------------------------
START:
; йОЙГЙБМЙЪБГЙС РТПЗТБННЩ
	MTPS	#340			; disable interrupts
	CLR	@#177560
	MTPS	#0			; enable interrupts
	MOV	SP, SAVESP
; 200 RETURN
N200:
	RETURN
; 210 RETURN
N210:
	RETURN
; 300 RETURN'with comment
N300:
	RETURN
LEND:
; ъБЧЕТЫЕОЙЕ РТПЗТБННЩ
SAVESP = . + 2
	MOV	#776, SP	; restore SP
	EMT	350		; .EXIT
; STRINGS
	.EVEN
ST0:	.WORD	0	; empty string
; RUNTIME CALLS
	.END	START
