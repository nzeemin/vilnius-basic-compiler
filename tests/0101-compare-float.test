-q
----------------------------------------------------------------------
T = 10
L = 11
Z = 0
'
? "== -1", T = 10
? "==  0", T = L
'
? "<> -1", T <> L
? "<>  0", T <> 10
'
? "<  -1", T < L
? "<   0", T < Z
? "<   0", T < 10
'
? "<= -1", T <= L
? "<=  0", T <= Z
? "<= -1", T <= 10
'
? ">= -1", L >= T
? ">=  0", Z >= T
? ">= -1", T >= 10
'
? ">  -1", L > T
? ">   0", Z > T
? ">  -1", T > 10
'
END
