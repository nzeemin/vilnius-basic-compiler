-q
----------------------------------------------------------------------
10 CLS
20 REM Const expressions test
25 PRINT "-1", 0% + 1% - 2%
30 PRINT "10", 0% - 10% + 20%
40 PRINT "25", 5% + 10% * 2%
45 PRINT "-9", 1% - 20% \ 2%
50 PRINT "9",  20% \ 2% - 1%
55 PRINT "19"  10% * 2% - 1%
60 PRINT "10"  (0% - 10%) + 20%
65 PRINT "10"  10% * (2% - 1%)
70 PRINT "1",  3% - 22% MOD 10%
75 PRINT "-9", (3% - 22%) MOD 10%
